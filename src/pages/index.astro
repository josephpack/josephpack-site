---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HomePosts from "../components/HomePosts.astro";
import ColorScript from "../components/ColorScript.astro";
import Tags from "../components/Tags.astro";
import { title, subtitle } from "../settings/settings.json";
import { Content as About } from "./about.md";
import getTags from "../scripts/getTags";

// This manually defines the variables Vercel was looking for
const SITE_TITLE = "josephpacksblog";
const SITE_DESCRIPTION = "I write words, do marketing, and make things.";

const posts = await getCollection("posts");
const tags = getTags(posts);

const lastThreePosts = posts.slice(0, 3);
---

<body>
    <Header />
    <main class="cassidoo-layout">
      <section class="hero">
        <div class="hero-text">
          <h1>Joseph Pack</h1>
          <p class="subtitle">I write words, do marketing, and make things</p>
        </div>
        <img src="/headshot.jpg" alt="Joseph Pack" class="headshot" />
      </section>

      <nav class="home-nav">
        <a href="/">home</a>
        <a href="/posts">blog</a>
        <a href="https://drugfreeadhd.org">adhd project</a>
      </nav>

      <div class="bio">
        <p>Hi! I'm Joseph. I was co-founder of <strong>Nativve</strong> and <strong>Nativve Research</strong>. I sold my shares in both companies in 2017 to travel the world and pursue new opportunities.</p>
        
        <p>I was co-owner of fintech startup, <strong>Fellow Pay</strong>. I left in 2021 to pursue a burning passion.</p>
        
        <p>That passion project is <a href="https://drugfreeadhd.org">drugfreeadhd.org</a>. Since then, I've taught my Drug Free ADHD Method to 1000s and coached dozens 1:1. Watch me explain the method on <a href="#">ADHD Chatter</a>.</p>
        
        <p>I do marketing consulting for clients that want to grow sustainably.</p>
        
        <p>I'm always building — audiences, websites, apps. I'm inspired by solving simple problems and strive to make the web a more human place.</p>
        
        <p>Read my <a href="/posts">book notes</a>.</p>
      </div>
    </main>

    <style>
      .cassidoo-layout {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }
      .hero {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2rem;
      }
      .hero-text h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
      }
      .subtitle {
        font-size: 1.2rem;
        color: #666;
      }
      .headshot {
        width: 180px;
        height: 180px;
        border-radius: 50%; /* This makes it a circle */
        object-fit: cover;
        border: 4px solid #f0f0f0;
      }
      .home-nav {
        margin-bottom: 2rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 1rem;
      }
      .home-nav a {
        margin-right: 1.5rem;
        text-decoration: none;
        font-weight: bold;
        color: #333;
      }
      .home-nav a:hover {
        border-bottom: 2px solid orange; /* Cassidy's signature style */
      }
      .bio p {
        line-height: 1.6;
        margin-bottom: 1.5rem;
        font-size: 1.1rem;
      }

      /* Stack the image on top for mobile phones */
      @media (max-width: 600px) {
        .hero {
          flex-direction: column-reverse;
          text-align: center;
        }
      }
    </style>
    <Footer />
    <ColorScript />
  </body>
